# ─────────────────────────────────────────────────────────────────────────────
# VIRAXIS — variáveis de ambiente
# Copie para .env e preencha os valores antes de subir.
#
# OPÇÃO A (Codespaces / Local): docker-compose sobe Postgres e Redis
# OPÇÃO B (Deploy gratuito sem CC): Supabase + Upstash + Render
#   → veja os comentários nas seções abaixo
# ─────────────────────────────────────────────────────────────────────────────

# ── Aplicação ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# ── Banco de dados ─────────────────────────────────────────────────────────────
# OPÇÃO A — Docker local / Codespaces (padrão)
POSTGRES_USER=viraxis
POSTGRES_PASSWORD=TROQUE_AQUI_senha_forte_32_chars
POSTGRES_DB=viraxis
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# OPÇÃO B — Supabase (grátis, sem cartão de crédito)
# Crie em: https://supabase.com → new project → Settings → Database
# Cole a "Connection string" (Transaction pooler, port 6543) em DATABASE_URL:
# DATABASE_URL=postgresql+asyncpg://postgres.[REF]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres
# POSTGRES_HOST, POSTGRES_USER etc. são ignorados se DATABASE_URL estiver definida.

# ── Redis / Celery ─────────────────────────────────────────────────────────────
# OPÇÃO A — Docker local / Codespaces
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# OPÇÃO B — Upstash (grátis, sem cartão de crédito)
# Crie em: https://upstash.com → new Redis → copie a "Redis URL"
# REDIS_URL=rediss://default:[TOKEN]@[HOST].upstash.io:6379
# CELERY_BROKER_URL=rediss://default:[TOKEN]@[HOST].upstash.io:6379
# CELERY_RESULT_BACKEND=rediss://default:[TOKEN]@[HOST].upstash.io:6379/1

# ── LLM ───────────────────────────────────────────────────────────────────────
# Groq (grátis, rápido — recomendado para dev):
# Chave em: https://console.groq.com/keys
LLM_API_KEY=gsk_COLE_SUA_CHAVE_GROQ_AQUI
LLM_MODEL=g