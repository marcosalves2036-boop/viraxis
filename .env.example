# ------------------------------------------------------------------ #
# VIRAXIS — variáveis de ambiente                                     #
# Copie este arquivo para .env e preencha os valores                  #
# NUNCA faça commit do .env — ele já está no .gitignore               #
# ------------------------------------------------------------------ #

# ── Ambiente ──────────────────────────────────────────────────────
ENVIRONMENT=development
# development | staging | production
DEBUG=true

# ── Banco de dados ────────────────────────────────────────────────
POSTGRES_USER=viraxis
POSTGRES_PASSWORD=viraxis_dev
POSTGRES_DB=viraxis
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# URL montada automaticamente pelo settings.py — não precisa preencher
# DATABASE_URL=postgresql+asyncpg://viraxis:viraxis_dev@localhost:5432/viraxis

# ── Redis / Celery ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Anthropic API ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# Obter em: https://console.anthropic.com

# ── Segurança ─────────────────────────────────────────────────────
SECRET_KEY=troque-por-uma-string-aleatoria-de-64-chars
# Gerar: python -c "import secrets; print(secrets.token_hex(32))"

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
# 10080 = 7 dias

# ── Cloudflare R2 (storage de vídeos) ────────────────────────────
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=viraxis-media
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
# Preencher quando ativar a fase de storage (Phase 2)

# ── Aplicação ─────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
